{
  "manifest_version": 3,
  "name": "Fidelity Wildcard Filter Overlay",
  "version": "1.0.0",
  "description": "Wildcard holdings filtering widget for Fidelity portfolio positions pages.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://digital.fidelity.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
